{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "analysis": {
      "analyzer": {
        "ik_smart_analyzer": {
          "type": "custom",
          "tokenizer": "ik_smart_tokenizer",
          "filter": ["lowercase"]
        },
        "ik_max_word_analyzer": {
          "type": "custom",
          "tokenizer": "ik_max_word_tokenizer",
          "filter": ["lowercase"]
        },
        "cjk_fallback_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["cjk_width", "lowercase", "cjk_bigram"]
        }
      },
      "tokenizer": {
        "ik_smart_tokenizer": {
          "type": "ik_smart"
        },
        "ik_max_word_tokenizer": {
          "type": "ik_max_word"
        }
      }
    }
  },
  "settings_fallback": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "analysis": {
      "analyzer": {
        "chinese_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["cjk_width", "lowercase", "cjk_bigram"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "id": {
        "type": "keyword"
      },
      "name": {
        "type": "text",
        "analyzer": "ik_smart_analyzer",
        "search_analyzer": "ik_smart_analyzer",
        "fields": {
          "keyword": { "type": "keyword" },
          "max_word": {
            "type": "text",
            "analyzer": "ik_max_word_analyzer"
          }
        }
      },
      "brand": {
        "type": "keyword",
        "fields": {
          "text": {
            "type": "text",
            "analyzer": "ik_smart_analyzer"
          }
        }
      },
      "manufacturer": {
        "type": "keyword",
        "fields": {
          "text": {
            "type": "text",
            "analyzer": "ik_smart_analyzer"
          }
        }
      },
      "model_number": {
        "type": "keyword"
      },
      "announcement_batch": {
        "type": "keyword"
      },
      "announcement_date": {
        "type": "date",
        "format": "yyyy-MM-dd||yyyy-MM||epoch_millis"
      },

      "vehicle_type": {
        "type": "keyword"
      },
      "vehicle_category": {
        "type": "keyword"
      },
      "purpose": {
